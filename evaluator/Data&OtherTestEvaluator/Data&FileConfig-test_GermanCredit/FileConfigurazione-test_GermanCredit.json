{
  "datasets": {
    "train": null,
    "X_test": "Data&OtherTestEvaluator/Data&FileConfig-test_GermanCredit/X_test_credit.csv",
    "y_true": "Data&OtherTestEvaluator/Data&FileConfig-test_GermanCredit/y_true_credit.csv",
    "y_pred": "Data&OtherTestEvaluator/Data&FileConfig-test_GermanCredit/y_pred_credit.csv"
  },

  "model": {
    "path": null
  },
  
  "features": {
  "Attribute13": { "sensitive": true },
  "Attribute9": { "sensitive": true },
  "Attribute10": { "sensitive": true },
  "Attribute17": { "sensitive": true },
  "Attribute1":{ "sensitive": true }
},

  "postprocessing": {
  "use_inverse_encoding": false,
  "inverse_encoding_prefixes": [
    "gender_cv_",
    "nationality_cv_",
    "disability_cv_"
  ],
  "binning": {
    "use_binning": true,
    "features": {
      "Attribute13": {
        "bins": [16, 25, 35, 45, 55, 100],
        "labels": ["16-25", "26-35", "36-45", "46-55", "56+"]
      }
    }
  }
},

  "rights_to_evaluate": [
    "non_discrimination",
    "privacy"
  ],

  
  "metrics": {
    "non_discrimination": [
      "demographic_parity",
      "disparate_impact",
      "equal_opportunity",
      "equalized_odds_difference",
      "predictive_parity",
      "overall_accuracy_equality",
      "conditional_statistical_parity",
      "conditional_use_accuracy_equality"
      
    ],
    "privacy":[
      "anonymity_set_size",
      "k_anonymity",
      "l_diversity",
      "t_closeness",
      "mutual_information_metric"

    ]
  },

 
    "k_anonymity": {
        "enabled": true,
        "quasi_identifiers": ["Attribute13_binned", "Attribute9", "Attribute17"],
        "k_value": 2
                    },

    "l_diversity": {
      "enabled": true,
      "quasi_identifiers": ["Attribute13_binned", "Attribute9", "Attribute17"],
      "sensitive_attribute": "Attribute1"
                        },
                    
                    
    "t_closeness": {
      "enabled": true,
      "quasi_identifiers": ["Attribute13_binned", "Attribute9", "Attribute17"],
      "sensitive_attribute": "Attribute1"
                          },    

     "mutual_information": {
      "sensitive_attribute": "Attribute17",
      "columns_to_exclude": ["Attribute13_binned"]
      },

      "conditional_fairness": {
          "conditional_variable": "Attribute17"
          },

    
  "plugins": [
    "plugins.fairness.demographic_parity",
    "plugins.fairness.disparate_impact",
    "plugins.fairness.equal_opportunity",
    "plugins.fairness.equalized_odds_difference",
    "plugins.fairness.predictive_parity",
    "plugins.fairness.overall_accuracy_equality",
    "plugins.fairness.conditional_statistical_parity",
    "plugins.fairness.conditional_use_accuracy_equality",
    "plugins.privacy.anonymity_set_size",
    "plugins.privacy.k_anonymity",
    "plugins.privacy.l_diversity",
    "plugins.privacy.t_closeness",
    "plugins.privacy.mutual_information_metric"

  ]
}